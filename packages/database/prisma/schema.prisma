// Prisma Schema для AnimeStream

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Пользователи и авторизация

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  username  String   @unique
  avatar    String?
  role      Role     @default(USER)
  isBanned  Boolean  @default(false)
  banReason String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Связи
  comments        Comment[]
  favorites       Favorite[]
  watchHistory    WatchHistory[]
  reviews         Review[]
  likedComments   Comment[] @relation("LikedComments")
  dislikedComments Comment[] @relation("DislikedComments")

  @@index([email])
  @@index([role])
  @@map("users")
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

// Аниме тайтлы

model Anime {
  id          String   @id @default(uuid())
  title       String
  titleNative String?
  synonyms    String[]
  description String?
  coverImage  String?
  bannerImage String?
  trailerUrl  String?
  year        Int?
  status      AnimeStatus
  season      Season?
  episodes    Int      @default(0)
  duration    Int?     // длительность эпизода в минутах
  rating      Float    @default(0)
  popularity  Int      @default(0)
  genres      String[]
  tags        String[]
  studios     String[]
  sourceType  SourceType?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Связи
  episodeList   Episode[]
  favorites     Favorite[]
  watchHistory  WatchHistory[]
  reviews       Review[]
  relatedAnime  RelatedAnime[] @relation("RelatedFrom")
  relatedTo     RelatedAnime[] @relation("RelatedTo")

  @@index([title])
  @@index([year])
  @@index([status])
  @@index([rating])
  @@index([popularity])
  @@map("anime")
}

enum AnimeStatus {
  UNKNOWN
  FINISHED
  RELEASING
  NOT_YET_RELEASED
  CANCELLED
  HIATUS
}

enum Season {
  WINTER
  SPRING
  SUMMER
  FALL
}

enum SourceType {
  UNKNOWN
  ORIGINAL
  MANGA
  LIGHT_NOVEL
  VISUAL_NOVEL
  GAME
  NOVEL
  COMIC
  OTHER
}

// Эпизоды аниме

model Episode {
  id          String   @id @default(uuid())
  animeId     String
  number      Int
  title       String?
  titleNative String?
  description String?
  thumbnail   String?
  duration    Int?     // длительность в минутах
  airDate     DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Связи
  anime       Anime    @relation(fields: [animeId], references: [id], onDelete: Cascade)
  videoSources VideoSource[]
  watchHistory WatchHistory[]

  @@unique([animeId, number])
  @@index([animeId])
  @@map("episodes")
}

// Источники видео (плееры)

model VideoSource {
  id        String   @id @default(uuid())
  episodeId String
  name      String   // название плеера (например, "Kodik", "Alloha", "Sibnet")
  url       String   // URL источника
  quality   String?  // качество (1080p, 720p, etc.)
  type      VideoType @default(HLS)
  isActive  Boolean  @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Связи
  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@index([episodeId])
  @@map("video_sources")
}

enum VideoType {
  HLS
  MP4
  IFRAME
  DASH
}

// Озвучки (дабы)

model Dubbing {
  id        String   @id @default(uuid())
  name      String   @unique // название студии озвучки (например, "AniLibria", "SHIZA Project")
  logo      String?
  isActive  Boolean  @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Связи
  episodeDubs EpisodeDubbing[]

  @@map("dubbings")
}

model EpisodeDubbing {
  id        String   @id @default(uuid())
  episodeId String
  dubbingId String
  url       String   // URL видео с конкретной озвучкой
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Связи
  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  dubbing Dubbing @relation(fields: [dubbingId], references: [id], onDelete: Cascade)

  @@unique([episodeId, dubbingId])
  @@index([episodeId])
  @@map("episode_dubbings")
}

// Избранное

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  animeId   String
  status    FavoriteStatus
  score     Int?     // оценка пользователя (1-10)
  notes     String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Связи
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime Anime @relation(fields: [animeId], references: [id], onDelete: Cascade)

  @@unique([userId, animeId])
  @@index([userId])
  @@index([animeId])
  @@map("favorites")
}

enum FavoriteStatus {
  PLANNING
  WATCHING
  COMPLETED
  ON_HOLD
  DROPPED
}

// История просмотров

model WatchHistory {
  id           String   @id @default(uuid())
  userId       String
  animeId      String
  episodeId    String?
  progress     Int      @default(0) // номер последнего просмотренного эпизода
  watchedAt    DateTime @default(now())
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Связи
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime   Anime   @relation(fields: [animeId], references: [id], onDelete: Cascade)
  episode Episode? @relation(fields: [episodeId], references: [id], onDelete: SetNull)

  @@unique([userId, animeId])
  @@index([userId])
  @@index([animeId])
  @@map("watch_history")
}

// Комментарии

model Comment {
  id        String   @id @default(uuid())
  content   String
  parentId  String?
  animeId   String?
  userId    String
  isEdited  Boolean  @default(false)
  isDeleted Boolean  @default(false)
  likes     Int      @default(0)
  dislikes  Int      @default(0)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Связи
  parent     Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies    Comment[] @relation("CommentReplies")
  anime      Anime?    @relation(fields: [animeId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  likedBy    User[]    @relation("LikedComments")
  dislikedBy User[]    @relation("DislikedComments")

  @@index([animeId])
  @@index([userId])
  @@index([parentId])
  @@index([createdAt])
  @@map("comments")
}

// Отзывы/Рецензии

model Review {
  id        String   @id @default(uuid())
  userId    String
  animeId   String
  title     String
  content   String
  score     Int      // оценка 1-10
  isSpoiler Boolean  @default(false)
  likes     Int      @default(0)
  dislikes  Int      @default(0)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Связи
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime Anime @relation(fields: [animeId], references: [id], onDelete: Cascade)

  @@unique([userId, animeId])
  @@index([animeId])
  @@index([score])
  @@map("reviews")
}

// Связанные аниме

model RelatedAnime {
  id        String   @id @default(uuid())
  animeId   String
  relatedId String
  relation  RelationType

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Связи
  animeFrom Anime @relation("RelatedFrom", fields: [animeId], references: [id], onDelete: Cascade)
  animeTo   Anime @relation("RelatedTo", fields: [relatedId], references: [id], onDelete: Cascade)

  @@unique([animeId, relatedId])
  @@index([animeId])
  @@index([relatedId])
  @@map("related_anime")
}

enum RelationType {
  SEQUEL
  PREQUEL
  SIDE_STORY
  ALTERNATIVE
  SPIN_OFF
  SUMMARY
  OTHER
}

// Настройки приложения

model AppSettings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  type      SettingType @default(STRING)
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@index([key])
  @@map("app_settings")
}

enum SettingType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}
