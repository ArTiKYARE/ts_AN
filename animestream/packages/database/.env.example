# .env.example для пакета database
# Скопируйте этот файл в .env и заполните значениями

# PostgreSQL подключение
DATABASE_URL="postgresql://user:password@localhost:5432/animestream?schema=public"

# Для продакшена используйте более надёжный пароль и настройте SSL при необходимости
# DATABASE_URL="postgresql://user:strong_password@db-host:5432/animestream?schema=public&sslmode=require"
