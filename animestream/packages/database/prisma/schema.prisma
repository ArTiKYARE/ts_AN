generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum Role {
  USER
  MODERATOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
  PENDING
}

enum AnimeStatus {
  ONGOING
  COMPLETED
  ANNOUNCED
  HIATUS
}

enum SourceType {
  IFRAME
  HLS
  DIRECT
  CUSTOM
}

enum FavoriteStatus {
  PLANNING
  WATCHING
  COMPLETED
  DROPPED
  PAUSED
}

// Models
model User {
  id            String       @id @default(uuid())
  email         String       @unique
  password      String
  username      String       @unique
  avatar        String?
  role          Role         @default(USER)
  status        UserStatus   @default(ACTIVE)
  bio           String?      @db.Text
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  settings      UserSettings?
  refreshTokens RefreshToken[]
  comments      Comment[]
  favorites     Favorite[]
  watchHistory  WatchHistory[]
  commentLikes  CommentLike[]

  @@index([email])
  @@index([username])
  @@map("users")
}

model UserSettings {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  defaultPlayer String   @default("default")
  defaultDub    String   @default("russian")
  autoPlay      Boolean  @default(true)
  theme         String   @default("dark")
  language      String   @default("ru")
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("user_settings")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model Anime {
  id             String       @id @default(uuid())
  title          String
  slug           String       @unique
  description    String?      @db.Text
  poster         String?
  banner         String?
  trailer        String?
  
  year           Int?
  status         AnimeStatus  @default(ONGOING)
  rating         Float        @default(0)
  votes          Int          @default(0)
  
  externalId     String?
  source         String?
  
  seoTitle       String?
  seoDescription String?      @db.Text
  seoKeywords    String?      @db.Text
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  genres         Genre[]
  studios        Studio[]
  episodes       Episode[]
  comments       Comment[]
  favorites      Favorite[]
  watchHistory   WatchHistory[]
  synonyms       Synonym[]
  
  relatedFrom    RelatedAnime[] @relation("AnimeRelatedFrom")
  relatedTo      RelatedAnime[] @relation("AnimeRelatedTo")

  @@index([slug])
  @@index([title])
  @@index([year])
  @@index([status])
  @@index([rating])
  @@map("anime")
}

model Synonym {
  id      String @id @default(uuid())
  title   String
  animeId String
  anime   Anime  @relation(fields: [animeId], references: [id], onDelete: Cascade)

  @@index([title])
  @@map("synonyms")
}

model Genre {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  description String? @db.Text
  anime       Anime[]

  @@map("genres")
}

model Studio {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  description String? @db.Text
  anime       Anime[]

  @@map("studios")
}

model Episode {
  id          String   @id @default(uuid())
  animeId     String
  anime       Anime    @relation(fields: [animeId], references: [id], onDelete: Cascade)
  
  number      Int
  title       String?
  description String?  @db.Text
  duration    Int?
  airDate     DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  videoSources VideoSource[]
  watchHistory WatchHistory[]

  @@unique([animeId, number])
  @@index([animeId])
  @@map("episodes")
}

model VideoSource {
  id        String      @id @default(uuid())
  episodeId String
  episode   Episode     @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  
  name      String
  type      SourceType  @default(IFRAME)
  url       String
  
  priority  Int         @default(0)
  isActive  Boolean     @default(true)
  
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  dubs      Dub[]

  @@index([episodeId])
  @@map("video_sources")
}

model Dub {
  id        String      @id @default(uuid())
  sourceId  String
  source    VideoSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  
  name      String
  lang      String      @default("ru")
  url       String?
  isDefault Boolean     @default(false)
  
  createdAt DateTime    @default(now())

  @@index([sourceId])
  @@map("dubs")
}

model RelatedAnime {
  id           String @id @default(uuid())
  fromId       String
  from         Anime  @relation("AnimeRelatedFrom", fields: [fromId], references: [id], onDelete: Cascade)
  toId         String
  to           Anime  @relation("AnimeRelatedTo", fields: [toId], references: [id], onDelete: Cascade)
  relationType String

  @@unique([fromId, toId])
  @@index([fromId])
  @@index([toId])
  @@map("related_anime")
}

model Favorite {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  animeId   String
  anime     Anime         @relation(fields: [animeId], references: [id], onDelete: Cascade)
  status    FavoriteStatus @default(PLANNING)
  createdAt DateTime      @default(now())

  @@unique([userId, animeId])
  @@index([userId])
  @@index([animeId])
  @@map("favorites")
}

model WatchHistory {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  animeId   String
  anime     Anime     @relation(fields: [animeId], references: [id], onDelete: Cascade)
  episodeId String?
  episode   Episode?  @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  
  progress  Int       @default(0)
  completed Boolean   @default(false)
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, animeId, episodeId])
  @@index([userId])
  @@index([animeId])
  @@map("watch_history")
}

model Comment {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  animeId   String
  anime     Anime     @relation(fields: [animeId], references: [id], onDelete: Cascade)
  episodeId String?
  episode   Episode?  @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  
  content   String    @db.Text
  
  parentId  String?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  
  likes     Int       @default(0)
  dislikes  Int       @default(0)
  
  isDeleted Boolean   @default(false)
  isHidden  Boolean   @default(false)
  isEdited  Boolean   @default(false)
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  likesRelations CommentLike[]

  @@index([userId])
  @@index([animeId])
  @@index([episodeId])
  @@index([parentId])
  @@index([createdAt])
  @@map("comments")
}

model CommentLike {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  
  type      String
  createdAt DateTime @default(now())

  @@unique([userId, commentId])
  @@index([commentId])
  @@map("comment_likes")
}

model AdminLog {
  id        String   @id @default(uuid())
  adminId   String?
  action    String
  entity    String
  entityId  String?
  oldValue  String?  @db.Text
  newValue  String?  @db.Text
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([action])
  @@index([entity])
  @@map("admin_logs")
}

model SystemSettings {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String   @db.Text
  type        String   @default("string")
  category    String   @default("general")
  description String?
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@map("system_settings")
}

model ApiCache {
  id        String   @id @default(uuid())
  key       String   @unique
  endpoint  String
  data      String   @db.Text
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([endpoint])
  @@index([expiresAt])
  @@map("api_cache")
}