# ==========================================
# БАЗА ДАННЫХ (PostgreSQL)
# ==========================================
POSTGRES_USER=anime_user
POSTGRES_PASSWORD=secure_password_change_me
POSTGRES_DB=anime_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Строка подключения для Prisma/ORM (используется внутри контейнеров)
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"

# ==========================================
# КЭШИРОВАНИЕ (Redis)
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_password
REDIS_URL="redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}"

# ==========================================
# ПРИЛОЖЕНИЕ (API & Frontend)
# ==========================================
# Режим работы (development, production)
NODE_ENV=production

# Секретный ключ для JWT токенов (минимум 32 символа)
JWT_SECRET=super_secret_jwt_key_change_me_in_production_32chars_min
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# URL приложения (для CORS и редиректов)
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://api:4000

# ==========================================
# ВНЕШНИЕ API (Аниме данные)
# ==========================================
# Пример: Anilist, Shikimori или кастомный агрегатор
ANIME_API_KEY=your_external_api_key_here
ANIME_API_URL=https://graphql.anilist.co
# Таймаут запросов к внешнему API (мс)
EXTERNAL_API_TIMEOUT=5000
# TTL кэша для внешних данных (секунды)
EXTERNAL_CACHE_TTL=3600

# ==========================================
# АДМИН ПАНЕЛЬ
# ==========================================
# Данные первого администратора (создаются при старте)
ADMIN_EMAIL=admin@animestream.local
ADMIN_PASSWORD=AdminPassword123!
ADMIN_USERNAME=SuperAdmin

# ==========================================
# БЕЗОПАСНОСТЬ
# ==========================================
# Rate limiting (запросов в минуту)
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
