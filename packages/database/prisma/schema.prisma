// ==========================================
// Prisma схема для AnimeStream
// ==========================================

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------
// Пользователи и авторизация
// ------------------------------------------

/// Роль пользователя в системе
enum Role {
  USER      // Обычный пользователь
  MODERATOR // Модератор контента
  ADMIN     // Администратор
}

/// Статус аккаунта пользователя
enum UserStatus {
  ACTIVE    // Активен
  BANNED    // Заблокирован
  PENDING   // Ожидает подтверждения
}

/// Модель пользователя
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  username      String    @unique
  passwordHash  String
  role          Role      @default(USER)
  status        UserStatus @default(ACTIVE)
  avatar        String?
  bio           String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?
  
  // Связи
  comments      Comment[]
  favorites     Favorite[]
  watchHistory  WatchHistory[]
  settings      UserSettings?
  
  @@index([email])
  @@index([username])
  @@map("users")
}

/// Настройки пользователя
model UserSettings {
  id                String  @id @default(uuid())
  userId            String  @unique
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Настройки плеера
  defaultPlayer     String  @default("default")
  defaultDub        String  @default("russian")
  autoPlay          Boolean @default(true)
  autoNext          Boolean @default(true)
  
  // Настройки интерфейса
  theme             String  @default("dark") // dark, light, system
  language          String  @default("ru")
  
  // Уведомления
  emailNotifications Boolean @default(false)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@map("user_settings")
}

// ------------------------------------------
// Аниме контент
// ------------------------------------------

/// Статус аниме
enum AnimeStatus {
  ONGOING    // Онгоинг
  COMPLETED  // Завершено
  ANNOUNCED  // Анонсировано
  CANCELLED  // Отменено
  HIATUS     // Перерыв
}

/// Тип источника видео
enum SourceType {
  IFRAME   // iframe
  HLS      // HLS поток
  DIRECT   // Прямая ссылка
  YOUTUBE  // YouTube
  OTHER    // Другое
}

/// Основная модель аниме
model Anime {
  id          String      @id @default(uuid())
  externalId  String?     @unique // ID во внешнем API (Anilist, Shikimori)
  title       String
  titleNative String?     // Оригинальное название
  synonyms    String[]    // Синонимы/альтернативные названия
  description String?     @db.Text
  coverImage  String?     // Постер
  bannerImage String?     // Баннер
  trailerUrl  String?     // Трейлер
  
  year        Int?
  season      String?     // WINTER, SPRING, SUMMER, FALL
  episodes    Int         @default(0) // Общее количество эпизодов
  duration    Int?        // Длительность эпизода в минутах
  status      AnimeStatus @default(ONGOING)
  
  rating      Float?      // Средний рейтинг (0-10)
  popularity  Int         @default(0) // Количество просмотров
  
  genres      Genre[]
  studios     Studio[]
  
  episodes_list Episode[]
  comments    Comment[]
  favorites   Favorite[]
  watchHistory WatchHistory[]
  relatedAnime RelatedAnime[] @relation("relatedFrom")
  relatedTo   RelatedAnime[] @relation("relatedTo")
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  @@index([title])
  @@index([status])
  @@index([year])
  @@index([rating])
  @@map("anime")
}

/// Жанр
model Genre {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  animes    Anime[]
  
  @@map("genres")
}

/// Студия
model Studio {
  id        String   @id @default(uuid())
  name      String   @unique
  animes    Anime[]
  
  @@map("studios")
}

/// Эпизод аниме
model Episode {
  id          String   @id @default(uuid())
  animeId     String
  anime       Anime    @relation(fields: [animeId], references: [id], onDelete: Cascade)
  
  number      Int      // Номер эпизода
  title       String?  // Название эпизода
  description String?  @db.Text
  duration    Int?     // Длительность в минутах
  airDate     DateTime?
  
  sources     VideoSource[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([animeId, number])
  @@index([animeId])
  @@map("episodes")
}

/// Источник видео для эпизода
model VideoSource {
  id          String     @id @default(uuid())
  episodeId   String
  episode     Episode    @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  
  name        String     // Название плеера (например, "Kodik", "Alloha", "Sibnet")
  type        SourceType @default(IFRAME)
  url         String     // URL источника
  
  priority    Int        @default(0) // Приоритет отображения (чем выше, тем выше в списке)
  isActive    Boolean    @default(true)
  
  dubs        Dub[]
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  @@index([episodeId])
  @@map("video_sources")
}

/// Озвучка
model Dub {
  id          String      @id @default(uuid())
  sourceId    String
  source      VideoSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  
  name        String      // Название озвучки (например, "SHIZA Project", "AniLibria")
  language    String      @default("russian") // russian, japanese, english
  url         String?     // URL если отличается от основного источника
  
  isDefault   Boolean     @default(false)
  
  @@index([sourceId])
  @@map("dubs")
}

/// Связь между аниме (сиквел, приквел, спин-офф и т.д.)
model RelatedAnime {
  id        String   @id @default(uuid())
  fromId    String
  toId      String
  from      Anime    @relation("relatedFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to        Anime    @relation("relatedTo", fields: [toId], references: [id], onDelete: Cascade)
  
  relationType String // sequel, prequel, spin_off, side_story, alternative, summary
  
  @@unique([fromId, toId])
  @@index([fromId])
  @@index([toId])
  @@map("related_anime")
}

// ------------------------------------------
// Комментарии
// ------------------------------------------

/// Комментарий
model Comment {
  id        String    @id @default(uuid())
  content   String    @db.Text
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  animeId   String?
  anime     Anime?    @relation(fields: [animeId], references: [id], onDelete: Cascade)
  
  parentId  String?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  
  likes     Int       @default(0)
  dislikes  Int       @default(0)
  
  isEdited  Boolean   @default(false)
  isDeleted Boolean   @default(false) // Мягкое удаление
  isPinned  Boolean   @default(false)
  isHidden  Boolean   @default(false) // Скрыто модератором
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  @@index([animeId])
  @@index([authorId])
  @@index([parentId])
  @@map("comments")
}

// ------------------------------------------
// Избранное и история
// ------------------------------------------

/// Избранное
model Favorite {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  animeId   String
  anime     Anime    @relation(fields: [animeId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@unique([userId, animeId])
  @@index([userId])
  @@index([animeId])
  @@map("favorites")
}

/// История просмотров
model WatchHistory {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  animeId   String
  anime     Anime    @relation(fields: [animeId], references: [id], onDelete: Cascade)
  
  episodeId String?
  lastEpisode Int    @default(0) // Последний просмотренный эпизод
  
  progress  Float    @default(0) // Прогресс текущего эпизода (0-100%)
  watchedAt DateTime @default(now())
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([userId, animeId])
  @@index([userId])
  @@index([animeId])
  @@map("watch_history")
}

// ------------------------------------------
// Системные настройки
// ------------------------------------------

/// Системные настройки
model SystemSettings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.Text
  type      String   @default("string") // string, number, boolean, json
  category  String   @default("general")
  
  description String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([category])
  @@map("system_settings")
}

/// Лог действий администратора
model AdminLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String   // create, update, delete, ban, unban
  entity    String   // user, anime, comment
  entityId  String?
  details   String?  @db.Text
  ipAddress String?
  
  createdAt DateTime @default(now())
  
  @@index([adminId])
  @@index([action])
  @@index([createdAt])
  @@map("admin_logs")
}
