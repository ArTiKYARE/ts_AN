// Схема базы данных для проекта AnimeStream
// Используем PostgreSQL с ORM Prisma

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Перечисления для статусов и ролей

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum AnimeStatus {
  ONGOING     // Онгоинг
  COMPLETED   // Завершён
  ANNOUNCED   // Анонсирован
  CANCELLED   // Отменён
  HIATUS      // На паузе
}

enum EpisodeSourceType {
  IFRAME      // Встроенный плеер
  HLS         // HLS поток
  DIRECT      // Прямая ссылка
  EXTERNAL    // Внешняя ссылка
}

enum CommentStatus {
  VISIBLE     // Видимый
  HIDDEN      // Скрыт модератором
  DELETED     // Удалён
}

enum DubLanguage {
  RUSSIAN     // Русский
  JAPANESE    // Японский
  ENGLISH     // Английский
  UKRAINIAN   // Украинский
  OTHER       // Другой
}

// Основные модели

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // Хэшированный пароль
  username  String   @unique
  avatar    String?  // URL аватара
  role      UserRole @default(USER)
  isBanned  Boolean  @default(false)
  bannedAt  DateTime?
  bannedBy  String?  // ID администратора
  
  // Настройки пользователя
  defaultDub        DubLanguage? @default(RUSSIAN)
  theme             String       @default("dark") // dark, light, system
  notificationsEnabled Boolean   @default(true)
  
  // Связи
  comments          Comment[]
  favorites         Favorite[]
  watchHistory      WatchHistory[]
  refreshToken      RefreshToken?
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  
  @@index([email])
  @@index([username])
  @@index([role])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  
  createdAt DateTime @default(now())
  
  @@index([token])
}

model Anime {
  id          String     @id @default(uuid())
  anilistId   Int?       @unique // ID из внешнего API
  kitsuId     String?    @unique // ID из Kitsu
  
  title       String
  synonyms    String[]   // Альтернативные названия
  description String?    @db.Text
  
  poster      String?    // URL постера
  banner      String?    // URL баннера
  trailerUrl  String?    // URL трейлера
  
  year        Int?
  status      AnimeStatus @default(ONGOING)
  rating      Float?     @default(0)
  ratingCount Int        @default(0)
  
  duration    Int?       // Длительность эпизода в минутах
  totalEpisodes Int?     // Общее количество эпизодов
  
  genres      Genre[]
  studios     String[]   // Студии
  producers   String[]   // Продюсеры
  
  episodes    Episode[]
  comments    Comment[]
  favorites   Favorite[]
  watchHistory WatchHistory[]
  
  // Кэширование данных из внешнего API
  externalData  Json?    // Сырые данные из API
  externalDataUpdatedAt DateTime?
  
  views       BigInt     @default(0)
  
  isActive    Boolean    @default(true)
  isFeatured  Boolean    @default(false)
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  @@index([title])
  @@index([year])
  @@index([status])
  @@index([rating])
  @@index([anilistId])
  @@index([isActive])
  @@index([isFeatured])
}

model Genre {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  anilistId Int?     @unique
  
  animes    Anime[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([slug])
}

model Episode {
  id          String   @id @default(uuid())
  animeId     String
  anime       Anime    @relation(fields: [animeId], references: [id], onDelete: Cascade)
  
  number      Int      // Номер эпизода
  title       String?  // Название эпизода
  description String?  @db.Text
  
  thumbnail   String?  // URL превью
  duration    Int?     // Длительность в секундах
  
  airDate     DateTime?
  
  sources     EpisodeSource[]
  comments    Comment[]
  
  views       BigInt   @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([animeId, number])
  @@index([animeId])
  @@index([number])
}

model EpisodeSource {
  id        String            @id @default(uuid())
  episodeId String
  episode   Episode           @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  
  name      String            // Название источника (например, "Alloha", "Codress")
  type      EpisodeSourceType @default(IFRAME)
  url       String            @db.Text // URL видео или iframe
  
  priority  Int               @default(0) // Приоритет отображения
  isActive  Boolean           @default(true)
  
  dubs      Dub[]
  
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  
  @@index([episodeId])
  @@index([isActive])
}

model Dub {
  id        String      @id @default(uuid())
  sourceId  String
  source    EpisodeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  
  language  DubLanguage
  name      String      // Название озвучки (например, "SHIZA Project", "AniLibria")
  url       String      @db.Text // URL конкретной дорожки
  
  isDefault Boolean     @default(false)
  
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  
  @@index([sourceId])
}

model Comment {
  id        String        @id @default(uuid())
  content   String        @db.Text
  
  authorId  String
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  animeId   String?
  anime     Anime?        @relation(fields: [animeId], references: [id], onDelete: Cascade)
  
  episodeId String?
  episode   Episode?      @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  
  parentId  String?
  parent    Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[]     @relation("CommentReplies")
  
  status    CommentStatus @default(VISIBLE)
  
  likes     Int           @default(0)
  dislikes  Int           @default(0)
  
  isEdited  Boolean       @default(false)
  editedAt  DateTime?
  
  moderatedBy String?     // ID модератора
  moderatedAt DateTime?
  moderationReason String? @db.Text
  
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  
  @@index([authorId])
  @@index([animeId])
  @@index([episodeId])
  @@index([parentId])
  @@index([status])
  @@index([createdAt])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  animeId   String
  anime     Anime    @relation(fields: [animeId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@unique([userId, animeId])
  @@index([userId])
  @@index([animeId])
}

model WatchHistory {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  animeId   String
  anime     Anime    @relation(fields: [animeId], references: [id], onDelete: Cascade)
  
  episodeId String?
  episode   Episode? @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  
  progress  Int      @default(0) // Процент просмотра
  lastPosition Int   @default(0) // Позиция в секундах
  
  watchedAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([userId, animeId, episodeId])
  @@index([userId])
  @@index([animeId])
  @@index([watchedAt])
}

// Модель для кэширования запросов к внешним API
model ApiCache {
  id        String   @id @default(uuid())
  key       String   @unique // Уникальный ключ запроса
  data      Json     // Кэшированные данные
  expiresAt DateTime // Время истечения кэша
  
  createdAt DateTime @default(now())
  
  @@index([key])
  @@index([expiresAt])
}

// Модель для хранения настроек приложения
model AppSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json     // Значение настройки
  category  String   @default("general") // general, player, api, etc.
  
  description String?
  
  updatedAt DateTime @updatedAt
  
  @@index([category])
}

// Модель для логов действий администраторов
model AdminLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String   // Тип действия
  entity    String   // Сущность (user, anime, comment)
  entityId  String?  // ID сущности
  details   Json?    // Дополнительные данные
  
  ipAddress String?
  userAgent String?
  
  createdAt DateTime @default(now())
  
  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}
