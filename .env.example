# ======================================
# AnimeStream - Шаблон переменных окружения
# Скопируйте этот файл в .env и заполните значения
# ======================================

# База данных PostgreSQL
DB_USER=animestream
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION
DB_NAME=animestream
DB_PORT=5432

# Redis
REDIS_PORT=6379

# JWT Secret (ОБЯЗАТЕЛЬНО замените в production!)
JWT_SECRET=change-this-to-a-random-secure-string-in-production

# Порты сервисов
API_PORT=3001
WEB_PORT=3000
ADMIN_PORT=3002

# Node.js
NODE_ENV=production

# Внешние API (опционально)
ANILIST_API_URL=https://graphql.anilist.co
KITSU_API_URL=https://kitsu.io/api/edge

# Настройки кэша (в секундах)
CACHE_TTL_DEFAULT=3600
CACHE_TTL_ANIME=7200
CACHE_TTL_USER=1800

# Лимиты запросов (rate limiting)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS разрешенные origin (укажите свои домены в production)
CORS_ORIGIN=http://localhost:3000,http://localhost:3002

# Email (для восстановления пароля и уведомлений)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=AnimeStream <noreply@animestream.local>

# Файлы (максимальный размер загрузки в байтах)
MAX_FILE_SIZE=5242880

# Сессия
SESSION_SECRET=change-this-session-secret-in-production
SESSION_MAX_AGE=86400000